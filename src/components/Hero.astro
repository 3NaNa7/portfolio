<section id="hero" class="relative w-full min-h-[70vh] sm:min-h-screen bg-paper overflow-hidden flex flex-col justify-between">
  <!-- Overlay Content -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pt-16 sm:pt-24 md:pt-32 pb-8 flex-grow flex flex-col justify-center">
    <h1 class="font-heading text-4xl sm:text-6xl md:text-7xl text-ink leading-tight max-w-4xl">
     Hi, I'm Samuelson Boadu-Acheampong.
    </h1>
    <p class="font-body text-base sm:text-xl md:text-2xl text-ink/80 mt-4 max-w-2xl">
       Junior Developer and Researcher, building playful and useful things.
    </p>
  </div>
  <!-- SVG Illustration Container -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <svg viewBox="0 0 1440 600" class="w-full h-full object-cover object-bottom"
     preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg">

        <!-- Sun/Orb -->
        <g id="hero-sun-group">
          <circle id="hero-sun" cx="1150" cy="60" r="50" fill="var(--color-amber)" />
        </g>
        <!-- Clouds -->
        <g id="hero-cloud-1-group">
          <ellipse id="hero-cloud-1" cx="300" cy="80" rx="70" ry="25" fill="#FFFFFF" opacity="1" />
        </g>
        <g id="hero-cloud-3-group">
          <ellipse id="hero-cloud-3" cx="600" cy="100" rx="80" ry="28" fill="#FFFFFF" opacity="1" />
        </g>
        <g id="hero-cloud-2-group">
          <ellipse id="hero-cloud-2" cx="850" cy="120" rx="90" ry="32" fill="#FFFFFF" opacity="1" />
        </g>
        <!-- Rolling Hills (back, middle, front) -->
        <!-- Back hill (lightest teal) -->
        <path d="M 0 350 Q 360 250, 720 380 T 1440 320 L 1440 600 L 0 600 Z" fill="
#A8CFC9" />
        <!-- Middle hill (mid teal) -->
        <path d="M 0 420 Q 400 320, 800 450 T 1440 400 L 1440 600 L 0 600 Z" fill="
#4E8F89" />
        <!-- Front hill (darkest teal / main teal theme color) -->
        <path d="M 0 490 Q 300 410, 600 510 T 1440 470 L 1440 600 L 0 600 Z" fill="var(--color-teal)" />
        <!-- Dashed Path & Companion Group (shifted together on mobile) -->
        <g id="hero-interactive-group">
          <!-- Dashed Path leading to companion -->
          <path id="hero-path" d="M 1490 550 C 1240 500, 1040 560, 840 480 C 640 400, 440 520, 290 460" fill="none"
          stroke="var(--color-ink)"
          stroke-width="3" stroke-dasharray="8 8" opacity="0.6" />
          <!-- Companion Character at (290, 460) — scaled to 36px to match rail companion -->
          <g id="hero-companion-scroll-wrapper" style="transform-box: fill-box; transform-origin: center;">
            <g id="hero-companion">
              <!-- Feet -->
              <ellipse cx="281" cy="462" rx="5" ry="2" fill="var(--color-coral)" />
              <ellipse cx="299" cy="462" rx="5" ry="2" fill="var(--color-coral)" />
              <!-- Body -->
              <ellipse cx="290" cy="450" rx="15" ry="11" fill="var(--color-coral)" />
              <!-- Eyes -->
              <circle cx="285" cy="447" r="2" fill="var(--color-ink)" />
              <circle cx="295" cy="447" r="2" fill="var(--color-ink)" />
            </g>
          </g>
        </g>
    </svg>
  </div>
  <!-- Scroll Down indicator -->
  <div class="relative z-10 w-full flex flex-col items-center pb-8 pt-4">
    <a href="#about" class="flex flex-col items-center space-y-1 text-ink/80 hover:text-teal transition-colors duration-200">
      <span class="font-body text-xs font-extrabold tracking-widest uppercase text-ink/90 mb-2">Scroll to explore</span>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"
      class="w-4 h-4 text-ink/60 animate-bounce">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </a>
  </div>
</section>
<style>
  /* Keyframes for Idle Animations */
  @keyframes floatSun {
    0%, 100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(12px, -12px);
    }
  }
   @keyframes driftCloud1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(14px, -18px); }
}
@keyframes driftCloud2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-10px, -22px); }
}
@keyframes driftCloud3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-6px, -26px); }
}
  @keyframes bobCompanion {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  /* SVG Element Selectors applying origin & boxes */
  #hero-sun {
    transform-box: fill-box;
    transform-origin: center;
    animation: floatSun 6s ease-in-out infinite;
  }
  #hero-cloud-1 {
    transform-box: fill-box;
    transform-origin: center;
    animation: driftCloud1 8s ease-in-out infinite;
  }
  #hero-cloud-2 {
    transform-box: fill-box;
    transform-origin: center;
    animation: driftCloud2 10s ease-in-out infinite;
  }
  #hero-cloud-3 {
    transform-box: fill-box;
    transform-origin: center;
    animation: driftCloud3 12s ease-in-out infinite;
  }
  #hero-companion {
    transform-box: fill-box;
    transform-origin: center;
    animation: bobCompanion 3s ease-in-out infinite;
  }

  /* Smooth transition for breakpoint shifts */
  #hero-sun-group,
  #hero-cloud-1-group,
  #hero-cloud-2-group,
  #hero-interactive-group {
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Fade and float transition for cloud 3 */
  #hero-cloud-3 {
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.6s cubic-bezier(0.25, 1, 0.5, 1), visibility 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    opacity: 1;
    visibility: visible;
  }

  /* Hide cloud 3 on all screen widths 1024px and below (tablets & mobile) to prevent overlapping */
  @media (max-width: 1024px) {
    #hero-cloud-3 {
      opacity: 0;
      visibility: hidden;
      transform: translate(-25px, 60px);
    }
  }

  /* Tablet positioning adjustments for SVG groups (641px - 1024px) */
  @media (min-width: 641px) and (max-width: 1024px) {
    #hero-sun-group {
      transform: translate(-260px, 15px);
    }
    #hero-cloud-1-group {
      transform: translate(220px, 10px);
    }
    #hero-cloud-2-group {
      transform: translate(-100px, 20px);
    }
    #hero-interactive-group {
      transform: translate(250px, 5px);
    }
  }

  /* Mobile positioning adjustments for SVG groups when cropped */
  @media (max-width: 640px) {
    #hero-sun-group {
      transform: translate(-300px, 30px);
    }
    #hero-cloud-1-group {
      transform: translate(250px, 20px);
    }
    #hero-cloud-2-group {
      transform: translate(-100px, 40px);
    }
    #hero-interactive-group {
      transform: translate(300px, 10px);
    }
  }
</style>

<script>
  // Dynamic scroll transition for the Hero companion and path to connect with the rail/bar
  const scrollWrapper = document.getElementById('hero-companion-scroll-wrapper');
  const path = document.getElementById('hero-path');

  if (scrollWrapper && path) {
    const handleScrollAnimation = () => {
      const scrollY = window.scrollY;
      // Animate transition over the first 250px of scroll
      const progress = Math.min(1, Math.max(0, scrollY / 250));
      const isMobile = window.innerWidth < 768;

      let tx = 0;
      let ty = 0;

      if (isMobile) {
        // On mobile/tablet, slide straight down towards the rising bottom bar
        tx = 0;
        ty = 250 * progress;
      } else {
        // On desktop, slide left/down towards the rail
        tx = -250 * progress;
        ty = 150 * progress;
      }

      const opacity = 1 - progress;

      scrollWrapper.style.transform = `translate(${tx}px, ${ty}px)`;
      scrollWrapper.style.opacity = opacity.toString();
      path.style.opacity = (0.6 * (1 - progress)).toString();
    };

    window.addEventListener('scroll', handleScrollAnimation, { passive: true });
    window.addEventListener('resize', handleScrollAnimation, { passive: true });
    // Initial run
    handleScrollAnimation();
  }
</script>