---
// NOTE TO USER: Personalize the bio paragraph below further with details of your own experience, interests, or background.
---

<section id="about" class="relative overflow-hidden w-full bg-paper py-16 sm:py-24 md:py-32">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="absolute top-0 left-0 w-full h-24 sm:h-32" aria-hidden="true">
  <path d="M0,50 Q360,15 720,45 T1440,30 L1440,0 L0,0 Z" fill="#A8CFC9" opacity="0.25" />
</svg>
  <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row gap-12 md:gap-16">

    <!-- Left side: Bio text -->
    <div class="flex-1 space-y-6">
      <!-- Illustrated Avatar, increase w,h,md values to increase size of avatar -->
      <div class="relative w-52 h-52 md:w-64 md:h-64 select-none pointer-events-none">
        <!-- Dashed Ring echoing Hero dashed path -->
        <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 100 100">
          <circle
            cx="50"
            cy="50"
            r="47"
            fill="none"
            stroke="var(--color-ink)"
            stroke-width="2"
            stroke-dasharray="5 5"
            opacity="0.25"
          />
        </svg>
        <!-- Circular Backdrop -->
        <div
          class="absolute bg-amber/20 rounded-full flex items-center justify-center overflow-hidden"
          style="inset: 4.5%;"
        >
          <img
            src="/avatar.svg"
            alt="Illustrated portrait of Samuelson Boadu-Acheampong"
            class="w-full h-full object-contain"
          />
        </div>
      </div>

      <h2 class="font-heading text-3xl sm:text-4xl text-ink">
        A bit about me
      </h2>
      <p class="font-body text-base sm:text-lg text-ink/80 leading-relaxed">
        I enjoy building software that sits at the intersection of user experience and intelligent systems.
        My background spans mobile development, web technologies, and machine learning research;
         from building Flutter applications to contributing to African Sign Language translation research.
      </p>
      <p class="font-body text-sm italic text-coral font-medium">
        "still learning as I build this site — that's kind of the point"
      </p>
    </div>

    <!-- Right side: Skills display -->
    <div class="flex-1 space-y-8">
      <div>
        <h3 class="font-heading text-xl text-ink mb-6">Curated Skillset</h3>

        <div class="space-y-6">
          <!-- Web -->
          <div>
            <h4 class="font-body text-xs font-bold uppercase tracking-wider text-ink/60 mb-2">Web</h4>
            <div class="flex flex-wrap gap-2">
              {['React', 'Next.js', 'Astro', 'TypeScript', 'Node.js/Express', 'Tailwind CSS'].map(skill => (
                <span class="font-body text-xs sm:text-sm px-3 py-1 bg-teal/30 text-ink rounded-full">{skill}</span>
              ))}
            </div>
          </div>

          <!-- Mobile -->
          <div>
            <h4 class="font-body text-xs font-bold uppercase tracking-wider text-ink/60 mb-2">Mobile</h4>
            <div class="flex flex-wrap gap-2">
              {['Flutter'].map(skill => (
                <span class="font-body text-xs sm:text-sm px-3 py-1 bg-amber/30 text-ink rounded-full">{skill}</span>
              ))}
            </div>
          </div>

          <!-- Languages -->
          <div>
            <h4 class="font-body text-xs font-bold uppercase tracking-wider text-ink/60 mb-2">Languages</h4>
            <div class="flex flex-wrap gap-2">
              {['C++', 'Java', 'Python'].map(skill => (
                <span class="font-body text-xs sm:text-sm px-3 py-1 bg-teal/30 text-ink rounded-full">{skill}</span>
              ))}
            </div>
          </div>

          <!-- Data & Infra -->
          <div>
            <h4 class="font-body text-xs font-bold uppercase tracking-wider text-ink/60 mb-2">Data & Infra</h4>
            <div class="flex flex-wrap gap-2">
              {['PostgreSQL', 'Firebase', 'Supabase', 'Git', 'Docker'].map(skill => (
                <span class="font-body text-xs sm:text-sm px-3 py-1 bg-amber/30 text-ink rounded-full">{skill}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Native HTML details disclosure widget -->
      <details class="group border border-ink/10 rounded-lg p-4 bg-ink/[0.02] transition-colors duration-200">
        <summary class="list-none flex items-center justify-between font-body text-sm font-semibold text-ink cursor-pointer hover:text-teal select-none outline-none">
          <span class="border-b border-dashed border-ink/40 group-hover:border-teal/40 pb-0.5">See full toolkit</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 transition-transform duration-200 group-open:rotate-180 text-ink/60">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>

        <div class="mt-6 pt-4 border-t border-ink/10 space-y-6">
          <!-- Web Extended -->
          <div>
            <h4 class="font-body text-xs font-bold uppercase tracking-wider text-ink/60 mb-2">Web (Extended)</h4>
            <div class="flex flex-wrap gap-2">
              {['HTML', 'CSS', 'JavaScript', 'Bootstrap', 'REST API design & integration', 'GraphQL', 'NextAuth.js', 'Webpack', ].map(skill => (
                <span class="font-body text-xs px-2.5 py-0.5 bg-ink/5 text-ink/80 rounded-full">{skill}</span>
              ))}
            </div>
          </div>

          <!-- Languages and Frameworks Extended -->
          <div>
            <h4 class="font-body text-xs font-bold uppercase tracking-wider text-ink/60 mb-2">Languages/Frameworks (Extended)</h4>
            <div class="flex flex-wrap gap-2">
              {[ 'SQL', 'Bash', 'The next time you visit, you should find more :)'].map(skill => (
                <span class="font-body text-xs px-2.5 py-0.5 bg-ink/5 text-ink/80 rounded-full">{skill}</span>
              ))}
            </div>
          </div>

          <!-- Data & Infra Extended -->
          <div>
            <h4 class="font-body text-xs font-bold uppercase tracking-wider text-ink/60 mb-2">Data & Infra (Extended)</h4>
            <div class="flex flex-wrap gap-2">
              {['MySQL', 'MongoDB', 'Linux/command line', 'GitHub Actions', 'AWS (S3/EC2)', 'Vercel',].map(skill => (
                <span class="font-body text-xs px-2.5 py-0.5 bg-ink/5 text-ink/80 rounded-full">{skill}</span>
              ))}
            </div>
          </div>

          <!-- Research & Sciences -->
          <div>
            <h4 class="font-body text-xs font-bold uppercase tracking-wider text-ink/60 mb-2">Research & Science</h4>
            <div class="flex flex-wrap gap-2">
              {['LaTeX', 'Overleaf', 'Data Analysis', 'Scientific Writing', 'Matlab', 'Pandas/NumPy', 'Jupyter'].map(skill => (
                <span class="font-body text-xs px-2.5 py-0.5 bg-ink/5 text-ink/80 rounded-full">{skill}</span>
              ))}
            </div>
          </div>
        </div>
      </details>
    </div>

  </div>
</section>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>
