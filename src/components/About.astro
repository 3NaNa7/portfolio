---
// NOTE TO USER: Personalize the bio paragraph below further with details of your own experience, interests, or background.
import SkillsGrid from './SkillsGrid.jsx';
---

<section id="about" class="relative overflow-hidden w-full bg-paper py-16 sm:py-24 md:py-32">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="absolute top-0 left-0 w-full h-24 sm:h-32" aria-hidden="true">
  <path d="M0,50 Q360,15 720,45 T1440,30 L1440,0 L0,0 Z" fill="#A8CFC9" opacity="0.25" />
</svg>
  <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row gap-12 md:gap-16">

    <!-- Left side: Bio text -->
    <div class="flex-1 space-y-6">
      <!-- Illustrated Avatar, increase w,h,md values to increase size of avatar -->
      <div class="relative w-52 h-52 md:w-64 md:h-64 select-none pointer-events-none">
        <!-- Dashed Ring echoing Hero dashed path -->
        <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 100 100">
          <circle
            cx="50"
            cy="50"
            r="47"
            fill="none"
            stroke="var(--color-ink)"
            stroke-width="2"
            stroke-dasharray="5 5"
            opacity="0.25"
          />
        </svg>
        <!-- Circular Backdrop -->
        <div
          class="absolute bg-amber/20 rounded-full flex items-center justify-center overflow-hidden"
          style="inset: 4.5%;"
        >
          <img
            src="/avatar.svg"
            alt="Illustrated portrait of Samuelson Boadu-Acheampong"
            class="w-full h-full object-contain"
          />
        </div>
      </div>

      <h2 class="font-heading text-3xl sm:text-4xl text-ink">
        A bit about me
      </h2>
      <p class="font-body text-base sm:text-lg text-ink/80 leading-relaxed">
        I enjoy building software that sits at the intersection of user experience and intelligent systems.
        My background spans mobile development, web technologies, and machine learning research;
         from building Flutter applications to contributing to African Sign Language translation research.
      </p>
      <p class="font-body text-sm italic text-coral font-medium">
        "still learning as I build this site — that's kind of the point"
      </p>
    </div>

    <!-- Right side: Skills grid -->
    <div class="flex-1 skills-reveal-wrapper">
      <h2 class="font-heading text-3xl sm:text-4xl text-ink mb-6">What I work with</h2>
      <SkillsGrid client:load />
    </div>

  </div>
</section>

<style>
  /* CSS-based scroll reveal that executes instantly without waiting for React hydration */
  .skills-reveal-wrapper {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: opacity, transform;
  }
  
  .skills-reveal-wrapper.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Vanilla JS observer to trigger scroll reveal instantly
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -10% 0px' });

  const wrapper = document.querySelector('.skills-reveal-wrapper');
  if (wrapper) {
    observer.observe(wrapper);
    
    // Fallback: If user scrolls extremely fast or JS is slow, 
    // ensure it shows up after a timeout just in case.
    setTimeout(() => {
      wrapper.classList.add('is-revealed');
    }, 1500);
  }
</script>

